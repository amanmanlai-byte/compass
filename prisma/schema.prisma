generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String?        @unique
  name          String?
  image         String?
  emailVerified DateTime?
  password      String?        // hashed password for email/password auth
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  settings      UserSettings?
  apiKeys       ApiKey[]
  accounts      Account[]
  sessions      Session[]
  profile       UserProfile?
  goals         Goal[]
  memories      Memory[]
  skillTags     SkillTag[]
  reviews       Review[]
  checkIns      CheckIn[]
  lifeMap       LifeMap?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  provider  String   // 'openai' | 'anthropic' | 'google' | 'deepseek' 等
  key       String   // AES-256-GCM 加密存储
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, provider])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("新对话")
  model     String    @default("openai:gpt-4o-mini")
  pinned    Boolean   @default(false)
  goalId    String?   // 关联目标
  tags      String?   // JSON: ["决策", "复盘", "闲聊"]
  summary   String?   // AI 生成的对话摘要
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  user      User      @relation(fields: [userId], references: [id])
  goal      Goal?     @relation(fields: [goalId], references: [id])

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // 'user' | 'assistant' | 'system'
  content        String
  tokens         Int?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model UserSettings {
  id               String @id @default(cuid())
  userId           String @unique
  theme            String @default("system")     // light | dark | system
  fontSize         String @default("md")         // sm | md | lg
  bubbleStyle      String @default("modern")     // modern | minimal | terminal | cute
  fontFamily       String @default("system")     // system | jetbrains-mono | pingfang
  codeTheme        String @default("github")     // github | dracula | nord | one-dark | solarized
  language         String @default("zh")
  systemPrompt     String @default("")
  streamingEnabled Boolean @default(true)
  temperature      Float  @default(0.7)
  maxTokens        Int    @default(4096)
  frequencyPenalty Float  @default(0.0)
  presencePenalty  Float  @default(0.0)
  contextLength    Int    @default(20)
  localEndpointUrl String @default("http://localhost:11434")
  defaultModel     String @default("openai:gpt-4o-mini")
  agentAvatar      String? // Agent 头像 data URL
  user             User   @relation(fields: [userId], references: [id])
}

model PresetPrompt {
  id        String   @id @default(cuid())
  userId    String
  name      String
  content   String   // Prompt 内容
  createdAt DateTime @default(now())

  @@index([userId])
}

model SharedConversation {
  id           String   @id @default(cuid())
  conversationId String @unique
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
}

model QuickCommand {
  id        String   @id @default(cuid())
  userId    String
  command   String   // e.g. '/translate'
  label     String
  prompt    String   // 指令内容
  createdAt DateTime @default(now())

  @@index([userId])
}

// ===== Compass 成长系统 =====

model UserProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?  // 一句话介绍自己
  lifeStage    String?  // 'student' | 'working' | 'freelance' | 'entrepreneur'
  coreValues   String?  // JSON: ["成长", "自由", "创造力"]
  strengths    String?  // JSON: ["决策力", "沟通力", "学习力"]
  weaknesses   String?  // JSON: ["拖延", "完美主义"]
  interests    String?  // JSON: ["产品设计", "心理学", "创业"]
  currentFocus String?  // 当前最重要的事
  avatar       String?  // 用户头像 data URL
  aiStyle      String?  // AI 自定义风格/人格描述
  onboardingDone Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id          String       @id @default(cuid())
  userId      String
  title       String       // "转行做产品经理"
  description String?
  category    String       // 'career' | 'skill' | 'health' | 'finance' | 'relationship' | 'custom'
  status      String       @default("active") // 'active' | 'completed' | 'paused' | 'abandoned'
  priority    Int          @default(0)
  targetDate  DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones  Milestone[]
  conversations Conversation[]

  @@index([userId, status])
}

model Milestone {
  id          String    @id @default(cuid())
  goalId      String
  title       String    // "完成产品课程"
  description String?
  status      String    @default("pending") // 'pending' | 'completed'
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Review {
  id           String   @id @default(cuid())
  userId       String
  period       String   // 'daily' | 'weekly' | 'monthly'
  periodStart  DateTime
  periodEnd    DateTime
  summary      String   // AI 生成的复盘摘要
  achievements String?  // JSON: ["完成了XX", "学到了YY"]
  challenges   String?  // JSON: ["遇到了ZZ"]
  nextSteps    String?  // JSON: ["下一步要做的"]
  mood         Int?     // 1-5 心情评分
  energy       Int?     // 1-5 精力评分
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, period, periodStart])
}

model Memory {
  id             String   @id @default(cuid())
  userId         String
  category       String   // 'fact' | 'preference' | 'goal' | 'emotion' | 'decision' | 'habit'
  content        String   // "用户计划在 2026 年底转行"
  source         String?  // 来源对话 ID
  importance     Int      @default(0) // 0-10 重要程度
  lastAccessedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
}

model SkillTag {
  id             String   @id @default(cuid())
  userId         String
  name           String   // "产品思维"
  level          Int      @default(1) // 1-10
  evidence       String?  // JSON: ["做了XX决策", "完成了YY项目"]
  lastAssessedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model CheckIn {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime //当天日期 (normalized to midnight)
  currentFocus    String?  // 你现在在做什么
  destination     String?  // 你想去哪
  todayPlan       String?  // 你今天要推进什么
  completedItems  String?  // JSON: [{text, completedAt}]
  blockers        String?  // JSON: [{text, reason: "forgot|afraid|unimportant|other"}]
  patternNote     String?  // AI 识别的模式笔记
  adjustmentSuggestion String? // AI 建议的调整
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ===== 人生地图 =====

model LifeMap {
  id              String     @id @default(cuid())
  userId          String     @unique
  currentPosition String?    // JSON: {stage, resources, constraints, focus}
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  paths           LifePath[]
}

model LifePath {
  id          String     @id @default(cuid())
  lifeMapId   String
  key         String     // 'survival' | 'skill' | 'income' | 'migration' | 'creation' | 'health'
  label       String     // 显示名称
  description String?
  color       String?    // 路径颜色 hex
  active      Boolean    @default(true)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  lifeMap     LifeMap    @relation(fields: [lifeMapId], references: [id], onDelete: Cascade)
  nodes       LifeNode[]

  @@index([lifeMapId])
}

model LifeNode {
  id              String       @id @default(cuid())
  lifePathId      String
  title           String       // "完成产品经理课程"
  description     String?
  status          String       @default("pending") // 'pending' | 'active' | 'completed' | 'skipped'
  abilityTags     String?      // JSON: ["产品思维", "用户研究"]
  historyNotes    String?      // JSON: [{date, note}]
  nextSuggestions String?      // JSON: ["建议下一步"]
  position        Int          @default(0) // 在路径上的顺序
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  lifePath        LifePath     @relation(fields: [lifePathId], references: [id], onDelete: Cascade)
  branches        LifeBranch[]

  @@index([lifePathId])
}

model LifeBranch {
  id           String   @id @default(cuid())
  lifeNodeId   String
  title        String   // "转向 UX 设计"
  description  String?
  abandonReason String? // 放弃原因
  cost         String?  // 成本描述
  consequence  String?  // 后果描述
  active       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lifeNode     LifeNode @relation(fields: [lifeNodeId], references: [id], onDelete: Cascade)

  @@index([lifeNodeId])
}
